@page "/"
@rendermode InteractiveServer

@using BgQuiz_Blazor.Quiz
@using XgFilter_Razor.Components
@using XgFilter_Lib.Filtering

@inject ProblemSetSelection Selection
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject QuizController Controller

<PageTitle>BgQuiz</PageTitle>

<div class="container py-3">
    <h1>BgQuiz</h1>

    <div class="alert alert-info" role="alert">
        <strong>Phase 1:</strong> cube decisions are not yet supported — quizzes
        run on checker plays only, regardless of the Decision-type filter below.
    </div>

    <div class="mb-3" style="max-width:800px">
        <label class="form-label" for="problemSetDir">
            Problem-set directory
            <small class="text-muted">(folder of .xg / .xgp files)</small>
        </label>
        <input id="problemSetDir" class="form-control"
               placeholder="e.g. D:\xg\quiz-positions"
               value="@Selection.Directory"
               @onchange="HandleDirectoryChangedAsync" />
        @if (!string.IsNullOrWhiteSpace(Selection.Directory) && !_directoryExists)
        {
            <div class="text-danger small mt-1">
                Directory not found.
            </div>
        }
    </div>

    <FilterPanel OnFilterConfigChanged="HandleFilterConfigApplied"
                 OnFilterDirty="HandleFiltersDirty" />

    <button class="btn btn-primary"
            disabled="@(!CanStart)"
            @onclick="StartQuizAsync">
        Start Quiz
    </button>

    @if (!_filtersApplied)
    {
        <small class="text-muted ms-2">Apply the filters above to enable Start.</small>
    }
    else if (string.IsNullOrWhiteSpace(Selection.Directory))
    {
        <small class="text-muted ms-2">Enter a problem-set directory to enable Start.</small>
    }

    @if (!string.IsNullOrEmpty(_startError))
    {
        <div class="alert alert-danger mt-3" role="alert">
            <strong>Could not start quiz:</strong> @_startError
        </div>
    }
</div>
