<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["BgQuiz_Blazor.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    @* Static fallback: the interactive outlet below cannot set a title until the
       ~19.5 MB WASM payload boots, and never does so for crawlers or no-JS clients. *@
    <title>BgQuiz</title>
    @* Every routable page is .Client-side with prerender: false, so a bare (static-pass)
       outlet would never receive their <PageTitle>. Emits nothing into the static pass,
       so there is no duplicate-<title> hazard. *@
    <HeadOutlet @rendermode="@(new InteractiveWebAssemblyRenderMode(prerender: false))" />
</head>

<body>
    <Routes />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
