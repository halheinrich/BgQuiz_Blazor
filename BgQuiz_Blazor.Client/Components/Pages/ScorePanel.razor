@using BgGame_Lib

@code {
    [Parameter, EditorRequired] public QuizScore Score { get; set; } = QuizScore.Empty;
    [Parameter] public int Skipped { get; set; }
    [Parameter] public string? Source { get; set; }
    [Parameter] public string? Heading { get; set; }

    // Accuracy is library-provided in [0, 1] (0 on an empty segment); the ×100
    // percentage rendering is a display concern that lives here, per
    // ScoreSegment's documented split — the same pattern ScoreBreakdown uses.
    private double PercentCorrect => Score.Total.Accuracy * 100;
}

<div class="score-panel mb-2 small text-muted">
    @if (!string.IsNullOrEmpty(Heading))
    {
        <strong class="me-2">@Heading</strong>
    }
    @if (!string.IsNullOrEmpty(Source))
    {
        <span class="me-3">Set: <code>@Source</code></span>
    }
    <span class="me-3">Submitted: <strong>@Score.Total.Submitted</strong></span>
    <span class="me-3">
        Correct: <strong>@Score.Total.Correct</strong>
        @if (Score.Total.Submitted > 0)
        {
            <text> (@PercentCorrect.ToString("0")%)</text>
        }
    </span>
    <span class="me-3">Skipped: <strong>@Skipped</strong></span>
    <span>Avg loss: <strong>@Score.Total.AverageEquityLoss.ToString("0.000")</strong></span>
</div>
