@page "/"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@using BgQuiz_Blazor.Client.Quiz
@using XgFilter_Razor.Components
@using XgFilter_Lib.Filtering

@inject IFolderAccess FolderAccess
@inject PickedProblemFolder Folder
@inject AppliedFilter AppliedFilter
@inject AppliedMix AppliedMix
@inject ShuffleOption ShuffleOption
@inject QuizStatsStore StatsStore
@inject NavigationManager Nav
@inject QuizController Controller
@inject QuizLiveMarker Marker

<PageTitle>BgQuiz</PageTitle>

<div class="container py-3">
    <h1>BgQuiz</h1>

    @* Reload-reset notice: a full reload rebooted the runtime and discarded a
       live quiz. An outcome the user should understand, not an error — polite
       role="status" (matching the no-match notice), not the assertive alert. *@
    @if (_showReloadNotice)
    {
        <div class="alert alert-info" role="status">
            Your previous quiz was reset by the page reload — quiz progress
            doesn't survive a full reload.
        </div>
    }

    <div class="mb-3" style="max-width:800px">
        <label class="form-label" for="pickProblemFolder">
            Problem-set folder
            <small class="text-muted">
                (a local folder of .xg / .xgp files — parsed in your browser, never uploaded)
            </small>
        </label>
        <div>
            <button type="button" id="pickProblemFolder" class="btn btn-outline-primary"
                    @onclick="PickFolderAsync">
                Choose folder…
            </button>
        </div>
        @* Fallback picker for browsers without showDirectoryPicker: a hidden
           webkitdirectory input, opened by the same button. Always rendered —
           not conditional on the capability probe — so the e2e suite can drive
           it directly and the probe stays a pick-time concern. The FileList is
           read by the JS module (Blazor's InputFile can't see
           webkitRelativePath, which the top-level-only filter needs). *@
        <input type="file" id="problemFolderFallback" webkitdirectory class="d-none"
               @ref="_fallbackInput" @onchange="HandleFallbackPickedAsync" />
        @if (!string.IsNullOrEmpty(Folder.Summary))
        {
            <div class="text-muted small mt-1 d-flex align-items-center gap-2">
                <span>@Folder.Summary</span>
                <button type="button" class="btn btn-link btn-sm p-0 align-baseline"
                        @onclick="ClearPickedFolderAsync">
                    Clear
                </button>
            </div>
        }
        @* Pick-time stats status: which rung of the degrade ladder this folder
           landed on. Outcomes the user should understand, not errors — polite
           role="status" like the other outcome notices. Rendered only while a
           pick is held (the capability is meaningless otherwise). *@
        @if (Folder.HasFiles)
        {
            @switch (Folder.Capability)
            {
                case StatsSaveCapability.Enabled:
                    <div class="alert alert-info mt-2" role="status">
                        Your lifetime quiz stats will be saved to
                        <strong>@QuizStatsFile.FileName</strong> in this folder.
                    </div>
                    break;
                case StatsSaveCapability.BrowserUnsupported:
                    <div class="alert alert-warning mt-2" role="status">
                        Your browser can't save quiz stats — the quiz runs without them.
                    </div>
                    break;
                case StatsSaveCapability.PermissionDenied:
                    <div class="alert alert-warning mt-2" role="status">
                        You declined write access — the quiz runs, but stats won't be saved.
                    </div>
                    break;
            }
        }
        @* Signal early (the weighted-mix half of the capability story): the
           user holds a committed non-blank mix, and this pick can't provide
           the lifetime stats it composes from — say so before Start, not at
           it. The Start gate remains the backstop (an unreadable stats file
           is only discoverable there). Polite: an advisory, not a failure. *@
        @if (Folder.HasFiles
             && Folder.Capability != StatsSaveCapability.Enabled
             && !AppliedMix.Current.IsPassthrough)
        {
            <div class="alert alert-warning mt-2" role="status">
                Your weighted mix composes from lifetime stats, which this pick
                can't provide — Start will offer to run without the mix.
            </div>
        }
        @* Empty-folder outcome (not a failure): a completed pick that yielded
           no problem files. Polite, like the no-match notice. *@
        @if (_emptyFolderNotice)
        {
            <div class="alert alert-warning mt-2" role="status">
                No .xg / .xgp files found directly in that folder.
            </div>
        }
        @if (!string.IsNullOrEmpty(_pickError))
        {
            <div class="alert alert-danger mt-2" role="alert">
                <strong>Could not read the folder:</strong> @_pickError
            </div>
        }
    </div>

    <FilterPanel OnFilterConfigChanged="HandleFilterConfigApplied"
                 OnFilterDirty="HandleFiltersDirty" />

    <MixPanel OnMixApplied="HandleMixApplied"
              OnMixRestored="HandleMixRestored"
              OnMixDirty="HandleMixDirty" />

    @* Disabled — not rewritten — while a committed mix owns presentation
       order: ShuffleOption keeps the user's value, so clearing the mix
       restores their prior shuffle preference untouched. *@
    <div class="mb-3 form-check">
        <input class="form-check-input" type="checkbox" id="shuffleOrder"
               checked="@ShuffleOption.Enabled" disabled="@MixOwnsOrder"
               @onchange="HandleShuffleToggled" />
        <label class="form-check-label" for="shuffleOrder">
            Shuffle order
            <small class="text-muted">
                @(MixOwnsOrder
                    ? "(order comes from the mix's Random order setting)"
                    : "(present problems in random order instead of file order)")
            </small>
        </label>
    </div>

    <button class="btn btn-primary"
            disabled="@(!CanStart)"
            @onclick="StartQuizAsync">
        Start Quiz
    </button>

    @if (!AppliedFilter.IsApplied)
    {
        <small class="text-muted ms-2">Apply the filters above to enable Start.</small>
    }
    else if (!Folder.HasFiles)
    {
        <small class="text-muted ms-2">Pick a folder containing .xg / .xgp files to enable Start.</small>
    }
    else if (AppliedMix.IsDirty)
    {
        <small class="text-muted ms-2">Apply or reset the mix above to enable Start.</small>
    }

    @if (!string.IsNullOrEmpty(_startError))
    {
        <div class="alert alert-danger mt-3" role="alert">
            <strong>Could not start quiz:</strong> @_startError
        </div>
    }

    @* Weighted-start refusal: the mix has entries but no lifetime stats are
       available, and running silently unweighted would substitute content the
       user didn't ask for. Actionable and assertive — the one-click per-run
       escape sits inside the notice; the stored mix is never touched. *@
    @if (_mixRefused)
    {
        <div class="alert alert-warning mt-3" role="alert">
            <p class="mb-2">
                Lifetime stats aren't available for this quiz
                (@MixDisplay.RefusalReason(Folder.Capability, StatsStore.Status)),
                so the weighted mix can't be applied.
            </p>
            <button class="btn btn-outline-primary btn-sm" id="startWithoutMix"
                    @onclick="StartWithoutMixAsync">
                Start without mix
            </button>
            <span class="small text-muted ms-2">
                runs this one quiz unweighted — or Reset the mix above to
                remove it; your saved mix is kept either way.
            </span>
        </div>
    }

    @* Empty-result outcome (not a failure): a valid Start that admitted no
       showable problem. role="status" (polite), not the error banner's
       assertive role="alert". *@
    @if (!string.IsNullOrEmpty(_noMatchNotice))
    {
        <div class="alert alert-warning mt-3" role="status">
            @_noMatchNotice
        </div>
    }

    @* Explicit-expression parens: bare "v@AppVersion" is parsed as an email literal. *@
    <div class="text-muted small mt-4">v@(AppVersion)</div>
</div>
