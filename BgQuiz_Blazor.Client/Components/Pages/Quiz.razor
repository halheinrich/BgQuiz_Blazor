@page "/quiz"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@using BgDataTypes_Lib
@using BackgammonDiagram_Lib
@using BgDiag_Razor.Components
@using BgQuiz_Blazor.Client.Quiz

@inject QuizController Controller
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>BgQuiz — In progress</PageTitle>

<div class="container py-3">
    @if (!Controller.HasStarted)
    {
        <div class="alert alert-warning" role="alert">
            No quiz in progress. <a href="/">Pick filters and start a quiz.</a>
        </div>
    }
    else if (Controller.Current is { } current)
    {
        <ScorePanel Score="Controller.Score"
                    Skipped="Controller.SkippedCount"
                    Source="@Controller.Name" />

        @if (Controller.Review is { } review)
        {
            <div class="board-container my-3">
                <XgidLabel Xgid="@current.Xgid" />
                <BackgammonDiagram Request="BuildSolutionRequest(current, review)"
                                   Options="_diagramOptions" />
            </div>

            @if (SolutionLegend(review, current.Decision) is { } legend)
            {
                <div class="text-muted small mb-2">@legend</div>
            }

            <div class="@VerdictCssClass(review)" role="status">
                @VerdictText(review)
            </div>

            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-primary" @onclick="ContinueAsync">
                    Continue
                </button>
                <button class="btn btn-outline-warning ms-auto" @onclick="RestartAsync">
                    Restart
                </button>
            </div>
        }
        else
        {
            <div class="board-container my-3">
                <XgidLabel Xgid="@current.Xgid" />
                @if (current.Decision.IsCube)
                {
                    <BackgammonCubeEntry Request="BuildRenderRequest(current)"
                                         Options="_diagramOptions"
                                         OnCubeDecisionCompleted="HandleCubeCompleted" />
                }
                else
                {
                    <BackgammonPlayEntry @ref="_playEntry"
                                         Request="BuildRenderRequest(current)"
                                         Options="_diagramOptions"
                                         OnPlayCompleted="HandlePlayCompleted"
                                         OnSubmitRequested="Submit" />
                }
            </div>

            <div class="d-flex flex-wrap gap-2">
                @if (current.Decision.IsCube)
                {
                    <button class="btn btn-primary"
                            disabled="@(_completedCube is null)"
                            @onclick="Submit">
                        Submit
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="SkipAsync">
                        Skip
                    </button>
                }
                else
                {
                    <button class="btn btn-primary"
                            disabled="@(_completedPlay is null)"
                            @onclick="Submit">
                        Submit
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="SkipAsync">
                        Skip
                    </button>
                    <button class="btn btn-outline-secondary"
                            disabled="@(_playEntry is null)"
                            @onclick="UndoLast">
                        Undo last
                    </button>
                    <button class="btn btn-outline-secondary"
                            disabled="@(_playEntry is null)"
                            @onclick="UndoAll">
                        Undo all
                    </button>
                }
                <button class="btn btn-outline-warning ms-auto" @onclick="RestartAsync">
                    Restart
                </button>
            </div>
        }
    }
</div>
