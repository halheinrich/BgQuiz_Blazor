@page "/quiz"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@using BgDataTypes_Lib
@using BackgammonDiagram_Lib
@using BgDiag_Razor.Components
@using BgQuiz_Blazor.Client.Quiz

@inject QuizController Controller
@inject QuizStatsStore StatsStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>BgQuiz — In progress</PageTitle>

@* app-busy: progress cursor while a Continue/Skip transition runs (app.css);
   the controller's gate yield lets it paint before the advance's churn. *@
<div class="container-fluid py-3 board-page @(Controller.IsBusy ? "app-busy" : null)">
    @* Active-context stats notices: scoped to the running quiz's stats context
       (bound at Start, reset by the next Start's re-bind). A load failure is an
       outcome — the quiz runs, the file stays untouched — so polite
       role="status"; a write failure is a failure mid-quiz, so the assertive
       alert idiom. Neither ever blocks the quiz. *@
    @if (StatsStore.Status == QuizStatsStatus.LoadFailed)
    {
        <div class="alert alert-warning" role="status">
            The existing <strong>@QuizStatsFile.FileName</strong> couldn't be read, so this
            quiz won't record stats. The file has not been changed.
        </div>
    }
    else if (StatsStore.Status == QuizStatsStatus.WriteFailed)
    {
        <div class="alert alert-danger" role="alert">
            Your stats file could not be saved — the quiz continues, but this
            quiz's stats won't be recorded.
        </div>
    }
    @* Mix notices, composition-first: whatever the framing, the first line is
       the quiz actually underway ("Your quiz has N problems: …"), rendered
       from every entry's actual draw. A capless mix gets a polite,
       composition-only status line — without a requested QuizLength the
       percentages bind to nothing, so an entry outdrawn by largest-remainder
       apportionment is composition noise, not a shortfall, and "requested"
       framing would misreport it (the producer guarantees Drawn == Target
       capless: the quiz is the whole deduped union). A length-bound mix keeps
       the honest shortfall alert (assertive — the quiz underway differs from
       what was asked), leading with the composition and demoting the
       per-entry apportionment internals to the explanation below it. *@
    @if (Controller.LastComposition is { } comp)
    {
        @if (!Controller.ActiveMixHasLength)
        {
            <div class="alert alert-info" role="status">
                @MixDisplay.CompositionSummary(comp)
            </div>
        }
        else if (HasShortfall(comp))
        {
            <div class="alert alert-warning" role="alert">
                <div>@MixDisplay.CompositionSummary(comp)</div>
                @if (comp.DrawnCount < comp.TargetCount)
                {
                    <div>
                        Your mix asked for @comp.TargetCount problems but only
                        @comp.DrawnCount could be drawn — these categories ran short:
                    </div>
                    <ul class="mb-0">
                        @foreach (var entry in comp.Entries.Where(e => e.Drawn < e.Requested))
                        {
                            <li>@MixDisplay.CategoryLabel(entry.Category): drew @entry.Drawn of @entry.Requested requested</li>
                        }
                    </ul>
                }
                else
                {
                    <div>
                        Some categories couldn't fill their share; the difference
                        went to the others:
                    </div>
                    <ul class="mb-0">
                        @foreach (var entry in comp.Entries.Where(e => e.Drawn < e.Requested))
                        {
                            <li>@MixDisplay.CategoryLabel(entry.Category): filled @entry.Drawn of its @entry.Percent% share (@entry.Requested requested)</li>
                        }
                    </ul>
                }
            </div>
        }
    }
    @if (!Controller.HasStarted)
    {
        <div class="alert alert-warning" role="alert">
            No quiz in progress. <a href="/">Pick filters and start a quiz.</a>
        </div>
    }
    else if (Controller.Current is { } current)
    {
        // Captured once: both the board branch and the chrome branch key off
        // review, and two separate `is { } review` patterns would collide in
        // the single generated render method's scope.
        var review = Controller.Review;

        @* Board on top; the chrome (score panel, legend, verdict, actions) sits
           in the full-width region below it. The board sizes width-first from
           this row and takes its height from the producer's own aspect-ratio —
           BgQuiz names no ratio anywhere. The XGID badge rides in the producer's
           Overlay slot (not a sibling of .board-container), so it tracks the
           rendered board box even when max-height letterboxes the board narrower
           than the row. *@
        <div class="board-container my-3">
            @if (review is not null)
            {
                <BackgammonDiagram Request="BuildSolutionRequest(current, review)"
                                   Options="_diagramOptions"
                                   OnDiceClicked="ContinueAsync">
                    <Overlay>
                        <XgidLabel Xgid="@current.Xgid" />
                    </Overlay>
                </BackgammonDiagram>
            }
            else if (current.Decision.IsCube)
            {
                @* Cube answering: the board region is board-only. The cube answer
                   is entered by the BackgammonCubeActions radios in the action row
                   below — not on the board — so this is the same read-only shape as
                   the review branch (a bare BackgammonDiagram in Problem mode). That
                   parity is the arc's whole point: the board sizes identically across
                   cube-answering, play-answering, and review. *@
                <BackgammonDiagram Request="BuildRenderRequest(current)"
                                   Options="_diagramOptions">
                    <Overlay>
                        <XgidLabel Xgid="@current.Xgid" />
                    </Overlay>
                </BackgammonDiagram>
            }
            else
            {
                <BackgammonPlayEntry @ref="_playEntry"
                                     Request="BuildRenderRequest(current)"
                                     Options="_diagramOptions"
                                     OnPlayCompleted="HandlePlayCompleted"
                                     OnSubmitRequested="Submit">
                    <Overlay>
                        <XgidLabel Xgid="@current.Xgid" />
                    </Overlay>
                </BackgammonPlayEntry>
            }
        </div>

        <div class="board-chrome">
            <ScorePanel Score="Controller.Score"
                        Skipped="Controller.SkippedCount"
                        Source="@Controller.Name"
                        ProblemNumber="Controller.ProblemNumber"
                        ProblemCount="Controller.ProblemCount" />

            @* State-invariant status strip: always present, fixed height, so the
               chrome's total height — and therefore the board's flex remainder,
               and therefore the board size — is identical across the answering
               and review states and across questions. While answering it carries
               a neutral prompt (legend line empty); at review the legend line
               and the verdict band fill in. Content changes; the box never does
               (long content clamps inside the fixed lines — see app.css). *@
            <div class="status-strip">
                <div class="status-legend text-muted small">
                    @(review is not null ? SolutionLegend(review, current.Decision) : null)
                </div>
                <div class="status-verdict alert @StatusVerdictColor(review)" role="status">
                    <span class="status-verdict-text">@StatusText(review, current.Decision)</span>
                </div>
            </div>

            @* Transition-driving buttons disable while the controller is busy
               (the gate would no-op them anyway — this is the honest mirror);
               Show stats stays enabled: it only navigates. *@
            @if (review is not null)
            {
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-primary" disabled="@Controller.IsBusy"
                            @onclick="ContinueAsync">
                        Continue
                    </button>
                    <button class="btn btn-outline-secondary" disabled="@Controller.IsBusy"
                            @onclick="RedoAsync">
                        Redo
                    </button>
                    <button class="btn btn-outline-secondary ms-auto" @onclick="ShowStats">
                        Show stats
                    </button>
                </div>
            }
            else
            {
                <div class="d-flex flex-wrap gap-2">
                    @if (current.Decision.IsCube)
                    {
                        @* The cube answer lives here in the chrome, beside its own
                           Submit / Skip — the board region above is board-only. The
                           radios lead the row (form order: choose, then Submit lights
                           up); @bind-Value keeps _completedCube current, which gates
                           Submit. There is no automatic reset — HandleStateChanged
                           nulls _completedCube on every advance, clearing the radios. *@
                        <BackgammonCubeActions @bind-Value="_completedCube" />
                        <button class="btn btn-primary"
                                disabled="@(_completedCube is null || Controller.IsBusy)"
                                @onclick="Submit">
                            Submit
                        </button>
                        <button class="btn btn-outline-secondary" disabled="@Controller.IsBusy"
                                @onclick="SkipAsync">
                            Skip
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-primary"
                                disabled="@(_completedPlay is null || Controller.IsBusy)"
                                @onclick="Submit">
                            Submit
                        </button>
                        <button class="btn btn-outline-secondary" disabled="@Controller.IsBusy"
                                @onclick="SkipAsync">
                            Skip
                        </button>
                        <button class="btn btn-outline-secondary"
                                disabled="@(_playEntry is null || Controller.IsBusy)"
                                @onclick="UndoLast">
                            Undo last
                        </button>
                        <button class="btn btn-outline-secondary"
                                disabled="@(_playEntry is null || Controller.IsBusy)"
                                @onclick="UndoAll">
                            Undo all
                        </button>
                    }
                    <button class="btn btn-outline-secondary ms-auto" @onclick="ShowStats">
                        Show stats
                    </button>
                </div>
            }
        </div>
    }
</div>
